# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Admin Auth ────────────────────────────────────────────────
# Restrict admin access to a specific email (optional).
# If set, only this email can log in to /admin.
# If left blank, any Supabase-authenticated user is treated as admin.
VITE_ADMIN_EMAIL=admin@yoursite.com

# ── SEO ───────────────────────────────────────────────────────
VITE_SITE_URL=https://your-app.vercel.app
